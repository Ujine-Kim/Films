{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/video/(.*)", "dest": "/public/video/$1" },
    { "src": "/(.*)", "dest": "/src/server.ts" }
  ]
}
